networks:
  mta:
    driver: bridge

volumes:
  postgres_data:
  nifi_conf:
  nifi_content:
  nifi_database:
  nifi_flowfile:
  nifi_provenance:
  superset_home:

services:

  # ─────────────────────────────────────────────
  #  PostgreSQL
  # ─────────────────────────────────────────────
  postgres:
    build:
      context: ./dockerfiles/postgres
      dockerfile: Dockerfile
    container_name: mta-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-admin}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-admin123}
      POSTGRES_DB: ${POSTGRES_DB:-mta}
    ports:
      - "5921:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./database/mta.sql:/docker-entrypoint-initdb.d/02_mta.sql:ro
      - ./database/seed.sql:/docker-entrypoint-initdb.d/03_seed.sql:ro
    networks:
      - mta
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-admin} -d ${POSTGRES_DB:-mta}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ─────────────────────────────────────────────
  #  FastAPI GTFS-RT Parser
  # ─────────────────────────────────────────────
  api:
    build:
      context: ./api
      dockerfile: ../dockerfiles/api/Dockerfile
    container_name: mta-api
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      POSTGRES_HOST: postgres
      POSTGRES_PORT: 5432
      POSTGRES_DB: ${POSTGRES_DB:-mta}
      POSTGRES_USER: ${POSTGRES_USER:-admin}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-admin123}
    ports:
      - "8902:8000"
    networks:
      - mta
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ─────────────────────────────────────────────
  #  Apache NiFi
  # ─────────────────────────────────────────────
  nifi:
    build:
      context: ./dockerfiles/nifi
      dockerfile: Dockerfile
    container_name: mta-nifi
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      NIFI_WEB_HTTP_HOST: 0.0.0.0
      NIFI_WEB_HTTP_PORT: 8080
      SINGLE_USER_CREDENTIALS_USERNAME: ${NIFI_USERNAME:-admin}
      SINGLE_USER_CREDENTIALS_PASSWORD: ${NIFI_PASSWORD:-adminpassword123}
      # PostgreSQL connection details passed as env vars (use in NiFi controllers)
      POSTGRES_HOST: postgres
      POSTGRES_PORT: 5432
      POSTGRES_DB: ${POSTGRES_DB:-mta}
      POSTGRES_USER: ${POSTGRES_USER:-admin}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-admin123}
    ports:
      - "8900:8080"
    volumes:
      - nifi_conf:/opt/nifi/nifi-current/conf
      - nifi_content:/opt/nifi/nifi-current/content_repository
      - nifi_database:/opt/nifi/nifi-current/database_repository
      - nifi_flowfile:/opt/nifi/nifi-current/flowfile_repository
      - nifi_provenance:/opt/nifi/nifi-current/provenance_repository
    networks:
      - mta
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/nifi/"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 60s

  # ─────────────────────────────────────────────
  #  Apache Superset
  # ─────────────────────────────────────────────
  superset:
    build:
      context: ./dockerfiles/superset
      dockerfile: Dockerfile
    container_name: mta-superset
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      SUPERSET_SECRET_KEY: ${SUPERSET_SECRET_KEY:-supersecretkey_change_me_in_prod}
      SUPERSET_ADMIN_USERNAME: ${SUPERSET_ADMIN_USERNAME:-admin}
      SUPERSET_ADMIN_PASSWORD: ${SUPERSET_ADMIN_PASSWORD:-admin123}
      SUPERSET_ADMIN_EMAIL: ${SUPERSET_ADMIN_EMAIL:-admin@example.com}
      # Superset metadata DB (uses the same postgres instance, different DB)
      DATABASE_URL: postgresql+psycopg2://${POSTGRES_USER:-admin}:${POSTGRES_PASSWORD:-admin123}@postgres:5432/superset
      # Data DB connection info (used by init script)
      DATA_DB_HOST: postgres
      DATA_DB_PORT: 5432
      DATA_DB_NAME: ${POSTGRES_DB:-mta}
      DATA_DB_USER: ${POSTGRES_USER:-admin}
      DATA_DB_PASS: ${POSTGRES_PASSWORD:-admin123}
    ports:
      - "8901:8088"
    volumes:
      - superset_home:/app/superset_home
    networks:
      - mta
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8088/health"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 90s
